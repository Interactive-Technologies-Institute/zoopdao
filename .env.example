# Supabase Configuration
# For local development, use the local Supabase instance
# Start Supabase locally with: supabase start

#project ID
PUBLIC_SUPABASE_URL=
#API Keys / Publishable key / default
PUBLIC_SUPABASE_ANON_KEY=

# For production, replace with your actual Supabase project credentials
# Get these from: https://app.supabase.com/project/_/settings/api

# AI Provider Configuration
# Active provider is configured in code (see src/routes/api/ai/messages/+server.ts).
# gemini
GEMINI_API_KEY=
# iaedu uses OpenAI GPT-4o
IAEDU_API_KEY=
IAEDU_ENDPOINT=
IAEDU_CHANNEL_ID=
# Optional fallback only. Round 7 V2 resolves thread_id dynamically per user/game/round via Supabase.
IAEDU_THREAD_ID=
# Optional: IP-based endpoint used when DNS fails (full URL if provided by IAEDU).
IAEDU_ENDPOINT_IP=

# Round 7 pipeline mode is now configured in code (see src/lib/config/feature-flags.ts).

# RAG ingestion (server-side)
SUPABASE_SERVICE_ROLE_KEY=
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_EMBEDDING_MODEL=baai/bge-m3
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=
