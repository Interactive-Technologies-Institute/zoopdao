# Supabase Configuration
# For local development, use the local Supabase instance
# Start Supabase locally with: supabase start
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=

# For production, replace with your actual Supabase project credentials
# Get these from: https://app.supabase.com/project/_/settings/api

# AI Provider Configuration
# Active provider is configured in code (see src/routes/api/ai/messages/+server.ts).
# gemini
GEMINI_API_KEY=
# iaedu uses OpenAI GPT-4o
IAEDU_API_KEY=
IAEDU_ENDPOINT=
IAEDU_CHANNEL_ID=
IAEDU_THREAD_ID=
# Optional: IP-based endpoint used when DNS fails (full URL if provided by IAEDU).
IAEDU_ENDPOINT_IP=
